{
  "module": {
    "name": "entry",
    "type": "entry",
    "description": "$string:module_desc",
    "mainElement": "EntryAbility",
    "deviceTypes": [
      "phone",
      "tablet"
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.INTERNET"
      }
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "abilities": [
      {
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "exported": true,
        "description": "$string:EntryAbility_desc",
        "icon": "$media:app_icon",
        "label": "$string:app_name",
        "startWindowIcon": "$media:app_icon",
        "startWindowBackground": "$color:start_window_background",
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "action.system.home"
            ]
          },
          {
            "entities": [
              "entity.system.share"
            ],
            "actions": [
              "ohos.want.action.sendData"
            ],
            "uris": [
              {
                "scheme": "http"
              },
              {
                "scheme": "https"
              }
            ]
          },
          {
            "entities": [
              "entity.system.default"
            ],
            "actions": [
              "ohos.want.action.sendData",
              "ohos.want.action.sendMultipleData",
              "ohos.want.action.sendToData",
              "ohos.want.action.choose"
            ],
            "uris": [
              {
                "type": "text/plain"
              },
              {
                "type": "text/*"
              },
              {
                "scheme": "",
                "utd": "general.hyperlink"
              },
              {
                "scheme": "",
                "utd": "general.plain-text"
              },
              {
                "scheme": "",
                "utd": "general.text"
              }
            ]
          },
          {
            "actions": [
              "ohos.want.action.sendData"
            ],
            "uris": [
              {
                "scheme": "file",
                "utd": "general.hyperlink",
                "maxFileSupported": 1
              },
              {
                "scheme": "file",
                "utd": "general.plain-text",
                "maxFileSupported": 1
              },
              {
                "scheme": "file",
                "utd": "general.text",
                "maxFileSupported": 1
              }
            ]
          },
          {
            "entities": [
              "entity.system.default"
            ],
            "actions": [
              "ohos.want.action.viewData"
            ],
            "uris": [
              {
                "scheme": "https"
              },
              {
                "scheme": "http"
              },
              {
                "type": "text/plain"
              },
              {
                "type": "text/uri-list"
              },
              {
                "scheme": "",
                "utd": "general.hyperlink"
              },
              {
                "scheme": "",
                "utd": "general.plain-text"
              },
              {
                "scheme": "",
                "utd": "general.text"
              }
            ]
          },
          {
            "entities": [
              "entity.system.browsable"
            ],
            "actions": [
              "ohos.want.action.viewData"
            ],
            "uris": [
              {
                "scheme": "https"
              },
              {
                "scheme": "http"
              }
            ]
          }
        ]
      }
    ]
  }
}
